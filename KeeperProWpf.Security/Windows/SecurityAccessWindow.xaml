<Window x:Class="KeeperProWpf.Security.Windows.SecurityAccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Работа с заявкой"
        Height="600"
        Width="850"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer>
        <StackPanel Margin="15">
            <TextBlock Text="Заявка" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Тип"/>
            <TextBox x:Name="TypeTextBox" IsReadOnly="True"/>

            <TextBlock Text="Подразделение" Margin="0,10,0,0"/>
            <TextBox x:Name="DepartmentTextBox" IsReadOnly="True"/>

            <TextBlock Text="Сотрудник" Margin="0,10,0,0"/>
            <TextBox x:Name="EmployeeTextBox" IsReadOnly="True"/>

            <TextBlock Text="Посетители" Margin="0,10,0,0"/>
            <ListBox x:Name="VisitorsListBox" Height="150"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Разрешить доступ" Width="150" Margin="0,0,10,0" Click="AllowAccessButton_Click"/>
                <Button Content="Зафиксировать убытие" Width="170" Margin="0,0,10,0" Click="ExitButton_Click"/>
                <Button Content="Закрыть" Width="120" Click="CloseButton_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>