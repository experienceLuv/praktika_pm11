<Window x:Class="KeeperProWpf.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сервис посетителя"
        Height="420"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="ХранительПРО"
                           FontSize="26"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Сервис посетителя"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock x:Name="WelcomeTextBlock"
                           Text="Добро пожаловать"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <Button Content="Оформить индивидуальную заявку"
                        Height="45"
                        Margin="0,0,0,15"
                        Click="OpenCreateRequestButton_Click"/>

                <Button Content="Просмотреть созданные заявки"
                        Height="45"
                        Margin="0,0,0,15"
                        Click="OpenRequestsButton_Click"/>

                <Button Content="Выход"
                        Height="45"
                        Click="LogoutButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>