<Window x:Class="KeeperProWpf.Windows.OfficeTerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал сотрудника общего отдела"
        Height="650"
        Width="1200"
        Icon="/Assets/Icons/icon_general_department.ico">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="TypeFilterComboBox" Width="150" Margin="0,0,10,0"/>
            <ComboBox x:Name="DepartmentFilterComboBox" Width="220" Margin="0,0,10,0"/>
            <ComboBox x:Name="StatusFilterComboBox" Width="180" Margin="0,0,10,0"/>
            <Button Content="Фильтр" Width="100" Margin="0,0,10,0" Click="FilterButton_Click"/>
            <Button Content="Сбросить" Width="100" Click="ResetButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="ApplicationsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ApplicationId}" Width="70"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding TypeName}" Width="120"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="160"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding EmployeeName}" Width="170"/>
                <DataGridTextColumn Header="Начало" Binding="{Binding DateStart}" Width="100"/>
                <DataGridTextColumn Header="Окончание" Binding="{Binding DateEnd}" Width="100"/>
                <DataGridTextColumn Header="Цель" Binding="{Binding VisitPurpose}" Width="180"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="130"/>
                <DataGridTextColumn Header="Посетители" Binding="{Binding VisitorNames}" Width="250"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Проверить заявку" Width="160" Margin="0,0,10,0" Click="OpenReviewButton_Click"/>
            <Button Content="Закрыть" Width="100" Click="CloseButton_Click"/>
            <Button Content="Отчеты"
        Width="120"
        Margin="0,0,10,0"
        Click="OpenReportsButton_Click"/>
            <Button Content="Тестовый отчет"
        Width="140"
        Margin="0,0,10,0"
        Click="TestAutoReportButton_Click"/>
        </StackPanel>
    </Grid>
</Window>