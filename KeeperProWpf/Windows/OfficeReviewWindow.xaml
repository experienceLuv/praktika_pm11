<Window x:Class="KeeperProWpf.Windows.OfficeReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Формальная проверка заявки"
        Height="700"
        Width="900"
        Icon="/Assets/Icons/icon_general_department.ico">
    <ScrollViewer>
        <StackPanel Margin="15">
            <TextBlock Text="Информация по заявке" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Тип"/>
            <TextBox x:Name="TypeTextBox" IsReadOnly="True"/>

            <TextBlock Text="Подразделение" Margin="0,10,0,0"/>
            <TextBox x:Name="DepartmentTextBox" IsReadOnly="True"/>

            <TextBlock Text="Сотрудник" Margin="0,10,0,0"/>
            <TextBox x:Name="EmployeeTextBox" IsReadOnly="True"/>

            <TextBlock Text="Цель посещения" Margin="0,10,0,0"/>
            <TextBox x:Name="PurposeTextBox" IsReadOnly="True"/>

            <TextBlock Text="Посетители" Margin="0,10,0,0"/>
            <ListBox x:Name="VisitorsListBox" Height="120"/>

            <TextBlock Text="Дата посещения" Margin="0,10,0,0"/>
            <DatePicker x:Name="VisitDatePicker"/>

            <TextBlock Text="Время посещения" Margin="0,10,0,0"/>
            <TextBox x:Name="VisitTimeTextBox"/>

            <TextBlock Text="Причина отклонения" Margin="0,10,0,0"/>
            <TextBox x:Name="RejectReasonTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Одобрить" Width="120" Margin="0,0,10,0" Click="ApproveButton_Click"/>
                <Button Content="Отклонить" Width="120" Margin="0,0,10,0" Click="RejectButton_Click"/>
                <Button Content="Закрыть" Width="120" Click="CloseButton_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>