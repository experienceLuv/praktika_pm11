<Window x:Class="KeeperProWpf.Office.Windows.OfficeReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчеты общего отдела"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Отчеты"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="PeriodTypeComboBox" Width="150" Margin="0,0,10,0"/>
            <DatePicker x:Name="ReportDatePicker" Width="160" Margin="0,0,10,0"/>
            <Button Content="Сформировать отчет посещений"
                    Width="220"
                    Margin="0,0,10,0"
                    Click="LoadVisitCountReport_Click"/>
            <Button Content="Список лиц на территории"
                    Width="200"
                    Click="LoadCurrentPersonsReport_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="Количество посещений по подразделениям"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   VerticalAlignment="Top"/>

        <DataGrid x:Name="VisitCountDataGrid"
                  Grid.Row="2"
                  Margin="0,30,0,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="*"/>
                <DataGridTextColumn Header="Количество посещений" Binding="{Binding VisitCount}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3"
                   Text="Лица, находящиеся сейчас на территории"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,15,0,10"/>

        <DataGrid x:Name="CurrentPersonsDataGrid"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="220"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding VisitorFullName}" Width="*"/>
                <DataGridTextColumn Header="Паспорт" Binding="{Binding Passport}" Width="180"/>
                <DataGridTextColumn Header="Время входа" Binding="{Binding EntryTime}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>