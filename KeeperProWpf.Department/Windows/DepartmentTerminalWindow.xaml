<Window x:Class="KeeperProWpf.Department.Windows.DepartmentTerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал сотрудника подразделения"
        Height="650"
        Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <DatePicker x:Name="DateFromPicker" Width="140" Margin="0,0,10,0"/>
            <DatePicker x:Name="DateToPicker" Width="140" Margin="0,0,10,0"/>
            <Button Content="Фильтр" Width="100" Margin="0,0,10,0" Click="FilterButton_Click"/>
            <Button Content="Сбросить" Width="100" Click="ResetButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="ApplicationsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ApplicationId}" Width="70"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding TypeName}" Width="120"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}" Width="180"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding EmployeeName}" Width="180"/>
                <DataGridTextColumn Header="Начало" Binding="{Binding DateStart}" Width="100"/>
                <DataGridTextColumn Header="Окончание" Binding="{Binding DateEnd}" Width="100"/>
                <DataGridTextColumn Header="Посетители" Binding="{Binding VisitorNames}" Width="280"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Открыть заявку" Width="160" Margin="0,0,10,0" Click="OpenButton_Click"/>
            <Button Content="Закрыть" Width="100" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>