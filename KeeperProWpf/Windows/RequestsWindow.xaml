<Window x:Class="KeeperProWpf.Windows.RequestsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мои заявки"
        Height="520"
        Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Просмотр созданных заявок"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <DataGrid x:Name="RequestsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="60"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Тип}" Width="100"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding Подразделение}" Width="180"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Сотрудник}" Width="180"/>
                <DataGridTextColumn Header="Начало" Binding="{Binding Начало}" Width="90"/>
                <DataGridTextColumn Header="Окончание" Binding="{Binding Окончание}" Width="90"/>
                <DataGridTextColumn Header="Цель посещения" Binding="{Binding Цель_посещения}" Width="180"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="110"/>
                <DataGridTextColumn Header="Причина отказа" Binding="{Binding Причина}" Width="170"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Обновить"
                    Width="120"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="RefreshButton_Click"/>

            <Button Content="Закрыть"
                    Width="120"
                    Height="34"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>