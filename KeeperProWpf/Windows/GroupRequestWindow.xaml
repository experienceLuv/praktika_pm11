<Window x:Class="KeeperProWpf.GroupRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Групповая заявка"
        Height="700"
        Width="1100">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Информация для пропуска" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
            <WrapPanel Margin="0,0,0,10">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Дата начала"/>
                    <DatePicker x:Name="DateStartPicker" Width="150"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Дата окончания"/>
                    <DatePicker x:Name="DateEndPicker" Width="150"/>
                </StackPanel>

                <StackPanel Width="300">
                    <TextBlock Text="Цель посещения"/>
                    <TextBox x:Name="PurposeTextBox"/>
                </StackPanel>
            </WrapPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Принимающая сторона" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
            <WrapPanel Margin="0,0,0,10">
                <StackPanel Margin="0,0,20,0" Width="250">
                    <TextBlock Text="Подразделение"/>
                    <ComboBox x:Name="DepartmentComboBox" SelectionChanged="DepartmentComboBox_SelectionChanged"/>
                </StackPanel>

                <StackPanel Width="250">
                    <TextBlock Text="Сотрудник"/>
                    <ComboBox x:Name="EmployeeComboBox"/>
                </StackPanel>
            </WrapPanel>

            <StackPanel Width="500">
                <TextBlock Text="Примечание"/>
                <TextBox x:Name="NoteTextBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="Список посетителей" Margin="0,0,0,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button x:Name="AddVisitorButton" Content="Добавить посетителя" Width="170" Margin="0,0,10,0" Click="AddVisitorButton_Click"/>
                    <Button x:Name="RemoveVisitorButton" Content="Удалить выбранного" Width="170" Click="RemoveVisitorButton_Click"/>
                </StackPanel>

                <DataGrid x:Name="VisitorsDataGrid" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="100"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                        <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="100"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                        <DataGridTextColumn Header="Организация" Binding="{Binding Organization}" Width="120"/>
                        <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=d}" Width="110"/>
                        <DataGridTextColumn Header="Серия паспорта" Binding="{Binding PassportSeries}" Width="110"/>
                        <DataGridTextColumn Header="Номер паспорта" Binding="{Binding PassportNumber}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <Button Grid.Row="3"
                x:Name="SaveGroupRequestButton"
                Content="Сохранить групповую заявку"
                Width="220"
                Height="35"
                HorizontalAlignment="Right"
                Click="SaveGroupRequestButton_Click"/>
    </Grid>
</Window>